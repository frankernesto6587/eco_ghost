{
  "name": "ecoghost",
  "version": "0.1.0",
  "private": true,
  "description": "EcoGhost - SaaS Financial Management Platform",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "dev:api": "turbo dev --filter=@ecoghost/api",
    "dev:web": "turbo dev --filter=@ecoghost/web",
    "build:api": "turbo build --filter=@ecoghost/api",
    "build:web": "turbo build --filter=@ecoghost/web",
    "db:migrate": "pnpm --filter @ecoghost/api prisma migrate dev",
    "db:push": "pnpm --filter @ecoghost/api prisma db push",
    "db:seed": "pnpm --filter @ecoghost/api prisma db seed",
    "db:studio": "pnpm --filter @ecoghost/api prisma studio"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "prisma",
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "@nestjs/core"
    ]
  }
}
